rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Validation helper
    function isValidLead(data) {
      return data.id is string 
        && data.customerName is string && data.customerName.size() <= 100
        && data.phone is string && data.phone.size() <= 20
        && data.email is string && data.email.size() <= 100
        && data.address is string && data.address.size() <= 200;
    }

    // Collection: leads_quotes
    match /leads_quotes/{id} {
      // Allow creation securely without auth (public quoting flow)
      allow create: if isValidLead(request.resource.data);
      
      // Allow reading specific quote by anyone who knows the ID (customer view) 
      // or if accessed by admin
      allow get: if true;
      allow list: if false; // Deny public list scraping to protect PII
      
      // Allow updates if it's changing state or booking details
      allow update: if isValidLead(request.resource.data);
      
      // Allow deletion only by admin
      allow delete: if false;
    }
  }
}
